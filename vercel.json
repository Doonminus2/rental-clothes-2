{
  "version": 2,
  "builds": [
    {
      "src": "rental-backend/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "."
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "rental-backend/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
